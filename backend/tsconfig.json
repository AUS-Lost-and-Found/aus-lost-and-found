{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2020",                          
    "lib": ["ES2020"],                           

    /* Modules */
    "module": "node16",                          
    "moduleResolution": "node16",                  
    "esModuleInterop": true,                     
    "resolveJsonModule": true,                   
    "allowSyntheticDefaultImports": true,        

    /* Output */
    "outDir": "./dist",                          
    "rootDir": "./src",                          

    /* Strictness */
    "strict": true,                              
    "skipLibCheck": true,                        

    /* Node.js */
    "types": ["node"]                            
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
